# =============================================================
# AI Director - Server-side environment variables template
# -------------------------------------------------------------
# 用法：
#   1. 复制本文件为 `.env.local`：
#        cp .env.local.example .env.local
#   2. 把等号右边的占位值替换成你自己的真实 Key
#   3. .env.local 已经在 .gitignore 中，不会被提交到 Git
#
# 安全提示：
#   - 本文件里的占位值都是 fake / 空值，绝对不要提交到 GitHub
#   - 不要使用 NEXT_PUBLIC_ 前缀（NEXT_PUBLIC_* 会被注入到客户端 bundle，
#     导致 Key 泄露）
#   - Key 只在服务端代码里读取（如 src/app/api/**/route.ts），
#     浏览器侧通过 /api/chat、/api/kling 等代理调用，永远不直接接触 Key
# =============================================================


# -------------------------------------------------------------
# 腾讯混元 AI（必填 — 想要接真实文本/分镜 AI 能力时）
# -------------------------------------------------------------
# 用途：分镜生成、视频脚本、文本润色
# 获取：https://console.cloud.tencent.com/hunyuan
# 留空 → /api/chat 返回 503，前端走 mock
HUNYUAN_API_KEY=


# -------------------------------------------------------------
# 可灵 AI（必填 — 想要接真实视频生成能力时）
# -------------------------------------------------------------
# 用途：视频生成 / 图生视频
# 获取：https://klingai.kuaishou.com/dev
# 留空 → 视频生成走 mock
KLING_API_KEY=
KLING_SECRET_ID=
KLING_SECRET_KEY=
KLING_API_BASE=https://api.klingai.com


# -------------------------------------------------------------
# AI 能力开关（可选 — 当前未消费）
# -------------------------------------------------------------
# 取值：
#   true   启用真实 AI 能力（需配置上述 Key）
#   false  走前端 mock（默认值，留空即可）
USE_REAL_AI=false


# -------------------------------------------------------------
# 以下变量由 Next.js / Vercel / Jest 自动注入，**不要**在此填写
# -------------------------------------------------------------
# NODE_ENV   - Next.js 自动设置
# PORT       - 已在 .env 中配置（3000），不要重复
# HOST       - 已在 .env 中配置（localhost），不要重复
